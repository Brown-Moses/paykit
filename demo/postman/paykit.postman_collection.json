{
  "info": {
    "name": "PayKit — Payment Event Engine (Full Test Suite)",
    "description": "Complete test suite for PayKit. Run in order using Collection Runner. Unique transaction IDs are generated automatically on every run — no DB reset needed between runs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8080" },
    { "key": "webhook_secret", "value": "test_secret" },
    { "key": "api_key",        "value": "" },
    { "key": "merchant_id",    "value": "" },
    { "key": "hmac_signature", "value": "" },
    { "key": "tx_success",     "value": "" },
    { "key": "tx_failed",      "value": "" },
    { "key": "tx_run_id",      "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// ── PayKit Auto-Signer ────────────────────────────────────────────",
          "// Generates a unique run ID once per collection run",
          "if (!pm.collectionVariables.get('tx_run_id')) {",
          "  const runId = 'RUN-' + Date.now();",
          "  pm.collectionVariables.set('tx_run_id', runId);",
          "  pm.collectionVariables.set('tx_success', 'TX-S-' + Date.now());",
          "  pm.collectionVariables.set('tx_failed',  'TX-F-' + (Date.now() + 1));",
          "}",
          "",
          "// Auto-compute HMAC-SHA256 for any request with X-Signature header",
          "const secret = pm.collectionVariables.get('webhook_secret');",
          "const body   = pm.request.body ? pm.request.body.raw : '';",
          "",
          "// Replace tx placeholders in body with actual run-specific IDs",
          "// (Postman doesn't resolve variables inside body for signing)",
          "let resolvedBody = body",
          "  .replace(/{{tx_success}}/g, pm.collectionVariables.get('tx_success'))",
          "  .replace(/{{tx_failed}}/g,  pm.collectionVariables.get('tx_failed'))",
          "  .replace(/{{tx_run_id}}/g,  pm.collectionVariables.get('tx_run_id'));",
          "",
          "const hasSignatureHeader = pm.request.headers.find(",
          "  function(h) { return h.key === 'X-Signature'; }",
          ");",
          "",
          "if (hasSignatureHeader && resolvedBody && secret) {",
          "  const signature = CryptoJS.HmacSHA256(resolvedBody, secret).toString();",
          "  pm.collectionVariables.set('hmac_signature', signature);",
          "  console.log('PayKit Auto-Signer ✓ signature: ' + signature.substring(0, 16) + '...');",
          "} else if (hasSignatureHeader && !secret) {",
          "  console.warn('PayKit Auto-Signer ✗ webhook_secret is empty');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Merchant",
      "item": [
        {
          "name": "1.1 Create Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Shop\",\n  \"webhook_url\": \"https://webhook.site/test\"\n}"
            },
            "url": "{{base_url}}/v1/merchants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('API key returned', function () {",
                  "  pm.expect(json.api_key).to.exist;",
                  "});",
                  "",
                  "pm.test('API key has pk_live_ prefix', function () {",
                  "  pm.expect(json.api_key).to.match(/^pk_live_/);",
                  "});",
                  "",
                  "pm.test('Merchant ID returned', function () {",
                  "  pm.expect(json.id).to.exist;",
                  "});",
                  "",
                  "pm.test('Save-key message present', function () {",
                  "  pm.expect(json.message).to.exist;",
                  "});",
                  "",
                  "// Save for all subsequent requests",
                  "pm.collectionVariables.set('api_key', json.api_key);",
                  "pm.collectionVariables.set('merchant_id', String(json.id));",
                  "console.log('Merchant created. ID:', json.id, '| Key:', json.api_key.substring(0, 12) + '...');"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Create Merchant — missing name",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"webhook_url\": \"https://webhook.site/test\"\n}"
            },
            "url": "{{base_url}}/v1/merchants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reject missing name — 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message present', function () {",
                  "  pm.expect(pm.response.json().error).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Create Merchant — no webhook URL",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"No Webhook Shop\"\n}"
            },
            "url": "{{base_url}}/v1/merchants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Merchant created without webhook URL — 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('API key still generated', function () {",
                  "  pm.expect(pm.response.json().api_key).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Webhooks",
      "item": [
        {
          "name": "2.1 Receive SUCCESSFUL payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Signature",  "value": "{{hmac_signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{tx_success}}\",\n  \"externalId\": \"order_987\",\n  \"amount\": \"1000\",\n  \"currency\": \"RWF\",\n  \"status\": \"SUCCESSFUL\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"2507XXXXXXX\"\n  },\n  \"timestamp\": \"2026-04-21T10:15:30Z\"\n}"
            },
            "url": "{{base_url}}/v1/webhook/momo/{{merchant_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Resolve variables then compute HMAC on the resolved body",
                  "const secret = pm.collectionVariables.get('webhook_secret');",
                  "const txId   = pm.collectionVariables.get('tx_success');",
                  "const body = JSON.stringify({",
                  "  transactionId: txId,",
                  "  externalId: 'order_987',",
                  "  amount: '1000',",
                  "  currency: 'RWF',",
                  "  status: 'SUCCESSFUL',",
                  "  payer: { partyIdType: 'MSISDN', partyId: '2507XXXXXXX' },",
                  "  timestamp: '2026-04-21T10:15:30Z'",
                  "});",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString();",
                  "pm.collectionVariables.set('hmac_signature', sig);",
                  "pm.collectionVariables.set('resolved_body_success', body);",
                  "console.log('Signing TX:', txId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time under 500ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Receive FAILED payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Signature",  "value": "{{hmac_signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{tx_failed}}\",\n  \"externalId\": \"order_988\",\n  \"amount\": \"2000\",\n  \"currency\": \"RWF\",\n  \"status\": \"FAILED\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"2507XXXXXXX\"\n  },\n  \"timestamp\": \"2026-04-21T11:00:00Z\"\n}"
            },
            "url": "{{base_url}}/v1/webhook/momo/{{merchant_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.collectionVariables.get('webhook_secret');",
                  "const txId   = pm.collectionVariables.get('tx_failed');",
