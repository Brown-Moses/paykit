              "raw": "{\n  \"transactionId\": \"TX-NO-SIG\",\n  \"externalId\": \"order_000\",\n  \"amount\": \"500\",\n  \"currency\": \"RWF\",\n  \"status\": \"SUCCESSFUL\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"2507XXXXXXX\"\n  },\n  \"timestamp\": \"2026-04-21T11:05:00Z\"\n}"
