        {
          "name": "2.5 Replay attack — same TX-SUCCESS again",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Signature",  "value": "{{hmac_signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{tx_success}}\",\n  \"externalId\": \"order_987\",\n  \"amount\": \"1000\",\n  \"currency\": \"RWF\",\n  \"status\": \"SUCCESSFUL\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"2507XXXXXXX\"\n  },\n  \"timestamp\": \"2026-04-21T10:15:30Z\"\n}"
            },
            "url": "{{base_url}}/v1/webhook/momo/{{merchant_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Reuse the same signature from 2.1 — same body, same TX",
                  "const secret = pm.collectionVariables.get('webhook_secret');",
                  "const txId   = pm.collectionVariables.get('tx_success');",
                  "const body = JSON.stringify({",
                  "  transactionId: txId,",
                  "  externalId: 'order_987',",
                  "  amount: '1000',",
                  "  currency: 'RWF',",
                  "  status: 'SUCCESSFUL',",
                  "  payer: { partyIdType: 'MSISDN', partyId: '2507XXXXXXX' },",
                  "  timestamp: '2026-04-21T10:15:30Z'",
                  "});",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString();",
                  "pm.collectionVariables.set('hmac_signature', sig);"
                ]
