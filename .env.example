# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/paykit
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=paykit
DATABASE_PASSWORD=change_me_in_env
DATABASE_NAME=paykit

# API Configuration
API_PORT=8080
API_HOST=localhost
API_ENV=development

# Payment Provider Configuration (MTN MoMo)
MOMO_WEBHOOK_SECRET=your_secret_from_mtn_portal
MOMO_API_KEY=YOUR_MTN_MOMO_API_KEY
MOMO_SUBSCRIBER_ID=YOUR_SUBSCRIBER_ID
MOMO_ENVIRONMENT=sandbox

# Authentication & Security
JWT_SECRET=change_me_with_strong_secure_secret
JWT_EXPIRY=24h
AUTH_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/paykit.log

# Deployment
ENVIRONMENT=development
# ENVIRONMENT=production (use for production)
